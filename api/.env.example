# EdgePulse API — environment variables
# Copy to /root/EdgePulse/.env and fill in real values before starting the service.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://edgepulse:CHANGE_ME@localhost/edgepulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ── Security (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_64_char_hex_string
# generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
MASTER_ENCRYPTION_KEY=CHANGE_ME_64_char_hex_string

# ── CORS (comma-separated, or JSON list) ──────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://your-dashboard-domain.com"]

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=120/minute
