# .env.example — EdgePulse environment variable reference
#
# Copy to .env and fill in your values.
# Both Intel and Exec nodes load this file via EnvironmentFile in systemd
# (or source it manually when using start.sh).
#
# Required vars are marked [REQUIRED].
# Optional vars show their runtime defaults in brackets.

# ── Node identity ─────────────────────────────────────────────────────────────
# Which role this process runs.  Intel node: MODE=intel  Exec node: MODE=exec
MODE=intel                                              # [REQUIRED on each node]
NODE_ID=intel-do-nyc3                                   # [REQUIRED on each node]

# ── Redis (shared bus between both nodes) ─────────────────────────────────────
# Intel node: Redis runs locally.  Exec node: point at Intel node's IP.
REDIS_URL=redis://localhost:6379/0                      # [REQUIRED]

# ── Kalshi API credentials (both nodes need these) ────────────────────────────
KALSHI_API_KEY_ID=your-api-key-id-here                  # [REQUIRED]
KALSHI_PRIVATE_KEY_PATH=/root/EdgePulse/private_key.pem # [REQUIRED]
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Paper trade mode — set to false only after live validation
KALSHI_PAPER_TRADE=true

# ── Coinbase Advanced Trade API (Intel node — BTC mean-reversion) ─────────────
COINBASE_API_KEY_NAME=organizations/YOUR-ORG-ID/apiKeys/YOUR-KEY-ID
COINBASE_PRIVATE_KEY_PATH=/root/EdgePulse/coinbase_key.pem
COINBASE_PAPER=true                                     # false = live BTC trades

# BTC position sizing
COINBASE_BTC_RISK_FRAC=0.02       # fraction of USD balance risked per BTC trade
COINBASE_BTC_MIN_SIZE=0.000016    # minimum order size in BTC

# ── External data APIs (Intel node) ───────────────────────────────────────────
POLYGON_API_KEY=your-polygon-key-here   # Polygon.io for BTC candles (free tier OK)
FRED_API_KEY=your-fred-key-here        # FRED for GDP and Fed Funds data (free)

# ── CME FedWatch API (OAuth2 client credentials + GCP WIF token exchange) ────
# Auth flow: POST auth.cmegroup.com → CME JWT → GCP STS token exchange → Bearer token
# Docs: https://cmegroupclientsite.atlassian.net/wiki/spaces/EPICSANDBOX/pages/457320466
# Endpoint schema: GET /forecasts → {meetingDt, reportingDt, rateRange:[{lowerRt, upperRt, probability}]}
CME_FEDWATCH_API_KEY_NAME=api_edgepulse                          # client_id (OAuth2)
CME_FEDWATCH_API_PASSWORD=                                       # client_secret
CME_FEDWATCH_AUTH_URL=https://auth.cmegroup.com/as/token.oauth2
CME_FEDWATCH_DATA_URL=https://markets.api.cmegroup.com/fedwatch/v1/forecasts

# Current Fed Funds upper target rate — updated from FRED automatically at startup
# Set as a fallback if FRED is unreachable
CURRENT_FED_RATE=3.75

# ── LLM policy agent ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here   # Claude API key
LLM_MODEL=claude-opus-4-6                   # model ID
LLM_INTERVAL_HOURS=4                        # how often Claude recalibrates
LLM_MAX_TOKENS=512

# ── Kalshi strategy parameters ────────────────────────────────────────────────
# Minimum edge above fair value to generate a signal (must exceed 7¢ fee)
KALSHI_EDGE_THRESHOLD=0.10

# Max contracts per single order
KALSHI_MAX_CONTRACTS=5

# Seconds between Intel scan cycles
KALSHI_POLL_INTERVAL=120

# Minimum model confidence (0–1); below 0.60 = single-source data
KALSHI_MIN_CONFIDENCE=0.60

# ── Kalshi risk management ────────────────────────────────────────────────────
KALSHI_KELLY_FRACTION=0.25          # quarter-Kelly sizing (conservative)
KALSHI_MAX_MARKET_EXPOSURE=0.05     # max % of balance in any single contract
KALSHI_MAX_TOTAL_EXPOSURE=0.30      # max % of balance across all Kalshi positions
KALSHI_DAILY_DRAWDOWN_LIMIT=0.20    # halt if daily loss exceeds this fraction
KALSHI_MAX_SPREAD_CENTS=10          # skip wide-spread markets
KALSHI_FEE_CENTS=7                  # Kalshi per-contract fee

# ── Kalshi exit management ────────────────────────────────────────────────────
KALSHI_TAKE_PROFIT_CENTS=20         # take profit threshold
KALSHI_STOP_LOSS_CENTS=15           # stop loss threshold
KALSHI_HOURS_BEFORE_CLOSE=24.0      # exit this many hours before expiry

# ── HTTP client ───────────────────────────────────────────────────────────────
KALSHI_HTTP_TIMEOUT=10
KALSHI_MAX_RETRIES=3
KALSHI_RETRY_BACKOFF=2.0
KALSHI_CONCURRENCY=10

# ── BTC mean-reversion strategy (ep_btc.py) ───────────────────────────────────
BTC_CANDLE_MIN=5                    # candle width in minutes
BTC_CANDLE_COUNT=100                # candles to fetch (100×5m = 8.3h history)
BTC_VOL_SPIKE_MULT=1.5              # skip entry if volume > this × 20-candle MA
BTC_TREND_THRESH=0.015              # skip entry if 20-SMA/50-SMA deviate > 1.5%
BTC_TREND_SMA=50                    # long-period SMA for trend filter
BTC_MAX_HOLD_HOURS=12               # force-exit BTC position after this many hours

# ── EdgePulse bus tuning (ep_config.py) ───────────────────────────────────────
EP_SIGNAL_TTL_MS=30000              # signals older than this are discarded (ms)
EP_STREAM_BLOCK_MS=5000             # Redis blocking read timeout (ms)
EP_EXIT_INTERVAL_S=60               # seconds between exit-checker sweeps

# ── Telegram trade alerts (ep_exec.py → ep_telegram.py) ──────────────────────
# Leave blank to disable. Get token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=                # @mychannel or numeric -100xxxxxxxxxx
TELEGRAM_ADMIN_ID=                  # optional — user ID for CRITICAL alerts
TELEGRAM_MIN_EDGE_TO_ALERT=0.0      # minimum edge for fill alerts

# ── Dashboard (Streamlit — started separately) ────────────────────────────────
# The dashboard reads directly from Redis. Start with:
#   streamlit run dashboard.py --server.port 8501 --server.address 0.0.0.0
DASHBOARD_REFRESH_S=3               # auto-refresh interval in seconds
NODE_STALE_S=120                    # seconds before node marked stale in UI

# ── Book-depth gate ───────────────────────────────────────────────────────────
MIN_BOOK_DEPTH=50         # min top-5 book depth for any entry [50]
MIN_BOOK_DEPTH_LONG=200   # stricter threshold for positions >90 days out [200]

# ── Infrastructure secrets ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
