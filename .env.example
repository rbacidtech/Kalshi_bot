# ── Kalshi API credentials ────────────────────────────────────────────────────
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=private_key.pem

# ── Mode ──────────────────────────────────────────────────────────────────────
# START HERE: paper trade until you have 2-4 weeks of validated signals
KALSHI_PAPER_TRADE=true

# ── Base URL (auto-selected if blank) ─────────────────────────────────────────
# Demo: https://demo-api.kalshi.co/trade-api/v2
# Live: https://api.elections.kalshi.com/trade-api/v2
KALSHI_BASE_URL=

# ── Strategy ──────────────────────────────────────────────────────────────────
# Minimum edge to trade. MUST exceed fees (7¢). Recommended: 10¢ minimum.
# Run paper trade at 10¢ first — if hit rate > 55% after 20+ trades, try 8¢.
KALSHI_EDGE_THRESHOLD=0.10

# Maximum contracts per order (start at 5, raise after paper-trade validation)
KALSHI_MAX_CONTRACTS=5

# Seconds between scan cycles (FOMC markets change slowly — 2 min is plenty)
KALSHI_POLL_INTERVAL=120

# Minimum model confidence to trade (0-1). Below 0.60 = single source, less reliable.
KALSHI_MIN_CONFIDENCE=0.60

# ── Risk management ───────────────────────────────────────────────────────────
# Kelly fraction: 0.25 = quarter-Kelly (conservative, recommended)
KALSHI_KELLY_FRACTION=0.25

# Max % of balance in any single FOMC contract
KALSHI_MAX_MARKET_EXPOSURE=0.05

# Max % of balance deployed across all open positions
KALSHI_MAX_TOTAL_EXPOSURE=0.30

# Halt trading if session balance drops by this fraction
KALSHI_DAILY_DRAWDOWN_LIMIT=0.10

# Skip markets with bid-ask spread wider than this (FOMC markets are tighter)
KALSHI_MAX_SPREAD_CENTS=10

# Estimated Kalshi fee per contract in cents
KALSHI_FEE_CENTS=7

# ── Exit management ───────────────────────────────────────────────────────────
# Take profit when position moves this many cents in our favor
KALSHI_TAKE_PROFIT_CENTS=20

# Cut loss when position moves this many cents against us
KALSHI_STOP_LOSS_CENTS=15

# Exit all positions this many hours before market resolves
KALSHI_HOURS_BEFORE_CLOSE=24.0

# ── Performance ───────────────────────────────────────────────────────────────
KALSHI_HTTP_TIMEOUT=10
KALSHI_MAX_RETRIES=3
KALSHI_RETRY_BACKOFF=2.0
KALSHI_CONCURRENCY=10

# ── Dashboard ──────────────────────────────────────────────────────────────────
# Set to false to disable the browser dashboard
KALSHI_DASHBOARD=true
KALSHI_DASHBOARD_PORT=5050

# ── SMS alerts (optional — requires free Twilio account) ───────────────────────
# Sign up at twilio.com, get a free number, then fill these in
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567
ALERT_PHONE_NUMBER=+15559876543

# ── Email alerts (optional) ────────────────────────────────────────────────────
# Works with Gmail (use an App Password, not your real password):
#   https://myaccount.google.com/apppasswords
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=you@gmail.com
ALERT_SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=you@gmail.com
ALERT_TO_EMAIL=you@gmail.com
