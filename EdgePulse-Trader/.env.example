# ──────────────────────────────────────────────────────────────────────────────
# EdgePulse-Trader — Environment Variables
# Copy to .env and fill in your values.  Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node identity ─────────────────────────────────────────────────────────────
# MODE=intel   → run the DO Droplet signal-generation node
# MODE=exec    → run the QuantVPS execution node
MODE=intel
NODE_ID=intel-do-nyc3

# ── Kalshi API credentials ────────────────────────────────────────────────────
# Leave blank to run in paper mode (no real orders placed)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/root/Kalshi_bot/private_key.pem

# Kalshi REST base URL
# Live:  https://trading-api.kalshi.com/trade-api/v2
# Demo:  https://demo-api.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# Paper mode — set to false to place real orders
KALSHI_PAPER_TRADE=true

# ── Polygon.io (BTC-USD OHLC — Personal $200/mo plan) ─────────────────────────
# Required for BTC mean-reversion signals. Leave blank to disable BTC signals.
POLYGON_API_KEY=

# ── Anthropic (Claude LLM policy agent) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Self-hosted via docker-compose: redis://localhost:6379/0
# DO Managed Redis: rediss://<user>:<password>@<host>:25061/0
REDIS_URL=redis://localhost:6379/0

# ── FRED API (optional — Fed rate anchor for FOMC signals) ────────────────────
FRED_API_KEY=

# Current Federal Funds Rate — used as FOMC signal anchor when FRED is unavailable
CURRENT_FED_RATE=3.75

# ── Strategy toggles ──────────────────────────────────────────────────────────
ENABLE_WEATHER=true
ENABLE_ECONOMIC=true
ENABLE_SPORTS=true

# ── Risk parameters ───────────────────────────────────────────────────────────
KALSHI_EDGE_THRESHOLD=0.10          # min fee-adjusted edge to signal (10¢)
KALSHI_KELLY_FRACTION=0.25          # quarter-Kelly sizing
KALSHI_MAX_CONTRACTS=5              # max contracts per signal
KALSHI_TAKE_PROFIT_CENTS=20         # take profit at +20¢ move
KALSHI_STOP_LOSS_CENTS=15           # stop loss at -15¢ move
KALSHI_MAX_SPREAD_CENTS=10          # reject signals with spread > 10¢
KALSHI_MIN_CONFIDENCE=0.60          # min model confidence

# ── BTC strategy parameters (overridable by LLM agent via ep:config) ──────────
BTC_RSI_PERIOD=14
BTC_BB_PERIOD=20
BTC_BB_STD=2.0
BTC_RSI_OVERSOLD=35
BTC_RSI_OVERBOUGHT=65
BTC_Z_THRESHOLD=1.5
BTC_CANDLE_MIN=5                    # 5-minute candles
BTC_CANDLE_COUNT=60                 # 60 candles = 5 hours of data

# ── LLM agent ─────────────────────────────────────────────────────────────────
LLM_MODEL=claude-opus-4-6
LLM_INTERVAL_HOURS=4                # how often Claude reviews the portfolio
LLM_MAX_TOKENS=512

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_PORT=9091                   # Prometheus scrape port (Intel: 9091, Exec: 9092)
DASHBOARD_REFRESH_S=3               # Streamlit dashboard refresh interval

# ── Alerts (optional — Twilio SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Alerts (optional — SMTP email) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
